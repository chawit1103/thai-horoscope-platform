# PR33 keeps real payment disabled by default. Use http only with approved staging/test credentials.
PAYMENT_PROVIDER_MODE=mock
PAYMENT_PROVIDER_CHECKOUT_ENDPOINT=
PAYMENT_PROVIDER_API_KEY=
PAYMENT_WEBHOOK_SECRET=

ENABLE_REAL_EMAIL_SENDS=false
ENABLE_REAL_LINE_SENDS=false
ENABLE_REAL_PAYMENT_PROVIDER=false
ENABLE_PROVIDER_DRY_RUN=true
REQUIRE_PROVIDER_ACTIVATION_APPROVAL=false

NOTIFICATION_SCHEDULER_MODE=disabled
NOTIFICATION_SCHEDULER_TOKEN=

